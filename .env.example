# --- $0 automated sources (recommended) ---
# Bluesky: free account + App Password (Settings → App passwords)
# Identifier is usually your handle, e.g. your.name.bsky.social
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=
# Optional: default is https://bsky.social (change only if you use another PDS)
# BLUESKY_PDS_HOST=https://bsky.social

# Mastodon: usually leave empty — many instances allow public hashtag reads.
# Set only if your chosen instance returns 401 and you create a token there.
# MASTODON_ACCESS_TOKEN=

# --- Optional paid / extras ---
# X recent search (often requires a paid tier)
# TWITTER_BEARER_TOKEN=

# Optional OpenAI for cleanup (costs money — omit for $0)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
