# --- Unofficial X scrape (required for data in CI) ---
# Export cookies while logged into x.com (see README). JSON array of cookie objects
# OR Playwright storage state file from a logged-in profile.
X_COOKIES_JSON=
# If the JSON is large, base64-encode the same string and use this instead:
# X_COOKIES_B64=
# Or path to a JSON file (local only):
# X_COOKIES_PATH=./x_cookies.json
# Or path to playwright storage_state.json (local only):
# X_STORAGE_STATE_PATH=./x_state.json

# Throttle (optional)
# X_MAX_QUERIES=8
# X_MAX_SCROLLS=7
# X_SCROLL_PAUSE=1.8
# X_SCRAPE_HEADLESS=1

# Optional OpenAI cleanup (costs money)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
