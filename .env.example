# --- Unofficial X scrape (required for data in CI) ---
#
# GitHub Actions: NOT a file in the repo. On GitHub open:
#   Repo → Settings → Secrets and variables → Actions → New repository secret
#   Name: X_COOKIES_JSON   Value: paste the same JSON array as one line (or use X_COOKIES_B64).
#
# Local: copy x_cookies.example.json → x_cookies.json, fill real values (x_cookies.json is gitignored).
X_COOKIES_PATH=./x_cookies.json
# Or paste JSON directly into .env (awkward for multiline — prefer X_COOKIES_PATH):
# X_COOKIES_JSON=
# If the JSON is large, base64-encode the whole string for GitHub secret X_COOKIES_B64:
# X_COOKIES_B64=
# Or path to playwright storage_state.json (local only):
# X_STORAGE_STATE_PATH=./x_state.json

# Throttle (optional)
# X_MAX_QUERIES=8
# X_MAX_SCROLLS=7
# X_SCROLL_PAUSE=1.8
# X_SCRAPE_HEADLESS=1

# Skip X browser step and only merge + internal screen backfill (optional)
# X_SKIP_SCRAPE=1
# Recompute internal screen for every row (optional)
# FORCE_SCREEN_BACKFILL=1
